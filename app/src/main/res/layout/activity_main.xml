<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <androidx.media3.ui.PlayerView
        android:id="@+id/playerView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:keepScreenOn="true"
        android:focusable="true"
        android:focusableInTouchMode="true" />

    <TextView
        android:id="@+id/statusText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|center_horizontal"
        android:layout_marginTop="28dp"
        android:background="#B3000000"
        android:paddingLeft="10dp"
        android:paddingTop="14dp"
        android:paddingRight="10dp"
        android:paddingBottom="14dp"
        android:textColor="#FFFFFF"
        android:textSize="12sp"
        android:visibility="gone" />

    <LinearLayout
        android:id="@+id/zapBanner"
        android:layout_width="360dp"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|start"
        android:layout_marginLeft="28dp"
        android:layout_marginBottom="28dp"
        android:background="#D9151A22"
        android:orientation="vertical"
        android:padding="6dp"
        android:visibility="gone">

        <TextView
            android:id="@+id/zapChannelText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:maxLines="1"
            android:textColor="#FFFFFF"
            android:textSize="22sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/zapMetaText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:maxLines="1"
            android:textColor="#CFE0F4"
            android:textSize="12sp" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/quickSearchOverlay"
        android:layout_width="340dp"
        android:layout_height="wrap_content"
        android:layout_gravity="top|start"
        android:layout_marginLeft="28dp"
        android:layout_marginTop="98dp"
        android:background="#E0161D27"
        android:orientation="vertical"
        android:padding="6dp"
        android:visibility="gone">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/quick_search_title"
            android:textAllCaps="true"
            android:textColor="#9FD0FF"
            android:textSize="12sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/quickSearchQueryText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/quickSearchResultText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:maxLines="3"
            android:textColor="#D5E6F8"
            android:textSize="12sp" />

        <TextView
            android:id="@+id/quickSearchHintText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:text="@string/quick_search_hint"
            android:textColor="#96AFC8"
            android:textSize="12sp" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/channelOverlay"
        android:layout_width="420dp"
        android:layout_height="match_parent"
        android:layout_gravity="end"
        android:background="@drawable/channel_overlay_panel_bg"
        android:orientation="vertical"
        android:paddingLeft="10dp"
        android:paddingTop="10dp"
        android:paddingRight="10dp"
        android:paddingBottom="10dp"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingBottom="4dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/channels_title"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/channel_overlay_chip_bg"
                android:paddingLeft="6dp"
                android:paddingTop="3dp"
                android:paddingRight="6dp"
                android:paddingBottom="3dp"
                android:text="@string/overlay_tools_hint"
                android:textColor="#DFF0FF"
                android:textSize="9sp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="4dp"
            android:background="@drawable/channel_overlay_card_bg"
            android:orientation="vertical"
            android:padding="6dp">

            <TextView
                android:id="@+id/overlayCurrentChannelText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:maxLines="1"
                android:textColor="#FFFFFF"
                android:textSize="13sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/overlayPlaybackRouteText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:ellipsize="end"
                android:maxLines="1"
                android:textColor="#F9FDFF"
                android:textSize="10sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/overlayCurrentMetaText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:visibility="gone" />

            <TextView
                android:id="@+id/overlayRecentText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:visibility="gone" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="4dp"
            android:background="@drawable/channel_overlay_section_bg"
            android:orientation="vertical"
            android:padding="6dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/filter_navigation_hint"
                android:textAllCaps="true"
                android:textColor="#8FB5D4"
                android:textSize="10sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/filterText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="@string/filter_all_label"
                android:textColor="#F3FAFF"
                android:textSize="14sp"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:background="@drawable/channel_overlay_section_bg"
            android:orientation="vertical"
            android:padding="6dp">

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/channelList"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:clipToPadding="false"
                android:descendantFocusability="beforeDescendants"
                android:focusable="false"
                android:overScrollMode="never"
                android:paddingTop="2dp"
                android:paddingBottom="4dp" />
        </LinearLayout>
    </LinearLayout>

    <TextView
        android:id="@+id/versionBadgeText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_marginRight="18dp"
        android:layout_marginBottom="18dp"
        android:background="#7A10151C"
        android:paddingLeft="8dp"
        android:paddingTop="4dp"
        android:paddingRight="8dp"
        android:paddingBottom="4dp"
        android:textColor="#D7E7F5"
        android:textSize="11sp"
        android:textStyle="bold" />

    <LinearLayout
        android:id="@+id/recordingsPanel"
        android:layout_width="560dp"
        android:layout_height="match_parent"
        android:layout_gravity="end"
        android:background="#EF171B22"
        android:orientation="vertical"
        android:padding="18dp"
        android:visibility="gone">

        <TextView
            android:id="@+id/recordingsSectionText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/title_recordings_visual"
            android:textColor="#FFFFFF"
            android:textSize="24sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="12dp"
            android:text="@string/recordings_panel_hint"
            android:textColor="#B8C8D8"
            android:textSize="13sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="14dp"
            android:background="#2F3540"
            android:orientation="horizontal"
            android:padding="14dp">

            <ImageView
                android:id="@+id/recordingDetailPosterImage"
                android:layout_width="86dp"
                android:layout_height="128dp"
                android:layout_marginEnd="14dp"
                android:background="#1F252F"
                android:contentDescription="@string/title_recordings"
                android:scaleType="centerCrop"
                android:visibility="gone" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/recordingDetailTitleText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:maxLines="2"
                    android:textColor="#FFFFFF"
                    android:textSize="20sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/recordingDetailMetaText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:textColor="#F2D5AF"
                    android:textSize="13sp" />

                <TextView
                    android:id="@+id/recordingDetailPathText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:maxLines="2"
                    android:textColor="#C7D2E2"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/recordingDetailActionText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:textColor="#9BD0FF"
                    android:textSize="12sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </LinearLayout>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recordingsRecyclerView"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:overScrollMode="never" />
    </LinearLayout>

    <TextView
        android:id="@+id/errorText"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#CC000000"
        android:gravity="center"
        android:lineSpacingExtra="6dp"
        android:padding="56dp"
        android:textColor="#FFFFFF"
        android:textSize="22sp"
        android:visibility="gone" />
</FrameLayout>
